# @ippoan scope (DO+WS lib @ippoan/mcp-cf-workers 等) は GitHub Packages 公開。
# CI / deploy では frontend-ci.yml が npm_scope:'@ippoan' で setup-node を構成し
# NODE_AUTH_TOKEN=GITHUB_TOKEN を注入する。ローカルは PAT (read:packages) を
# NODE_AUTH_TOKEN に入れるか、lib を file: link する。
@ippoan:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}

# `agents` (durable MCP transport、本repoが実際に使う) の optional peer
# `@cloudflare/ai-chat` が要求する `ai@^6.0.0` と、本repo自身の
# `@ai-sdk/react` (v4、ai@7系依存) が衝突する。ai-chat機能自体は未使用
# (McpAgent の DO base class としてのみ agents を使う) なので無視してよい
# (ippoan/gmail-mcp / ippoan/ci-dashboard / examples/cf-access-mcp と同じ対処)。
legacy-peer-deps=true
