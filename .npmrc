# @ippoan scope (DO+WS lib @ippoan/mcp-cf-workers 等) は GitHub Packages 公開。
# CI / deploy では frontend-ci.yml が npm_scope:'@ippoan' で setup-node を構成し
# NODE_AUTH_TOKEN=GITHUB_TOKEN を注入する。ローカルは PAT (read:packages) を
# NODE_AUTH_TOKEN に入れるか、lib を file: link する。
@ippoan:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
