{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "secrets-rotate-mcp",
  "main": "src/index.ts",
  "account_id": "24b45709d060d957340180e995f0d373",
  "compatibility_date": "2026-04-06",
  "observability": {
    "enabled": true
  },
  // top-level は `wrangler dev` (= local dev) 用。実 deploy は env.staging で
  // 行う (= 親 repo CLAUDE.md の「staging を実運用環境とする」と同じ pattern。
  // 既存 read worker secrets-inventory も同構造)。custom domain は staging env
  // 側にだけ bind する。
  // Phase B: 実 write 接続。tool は 3 provider (GCP proxy / CF API / GitHub
  // libsodium) に対して real call を行う。
  //
  // 認証 (Refs #43 で Phase A bearer → OAuth に切替):
  // - `/mcp*` route は CF Access で edge bypassAll、worker 側で
  //   `bindingJwtMiddleware` が auth-worker `binding_jwt` を verify。
  //   shared secret は持たず、claude.ai connector の OAuth 2.1
  //   auto-discovery (RFC 9728) を起点に `binding_jwt` を mint させる。
  // - browser dashboard route (= rotate-mcp は持たない) は引き続き
  //   CF Access で保護する想定 (= cf-access middleware は file として残置)。
  //
  // Bindings (write provider):
  // - GCP_PROXY_API_KEY: secrets-inventory-gcp Cloud Run proxy への shared
  //   secret (= secrets-inventory worker と同じ secret を流用、kebab-case)。
  //   proxy は POST /add-version endpoint を 1 つ提供 (= ippoan/secrets-
  //   inventory-gcp PR #23)。
  // - CF_API_TOKEN: CF API token (Secrets Store Edit scope 必要)。read 専用
  //   worker の token (read scope) とは **別 token** にすべき (= scope を
  //   write に絞った専用 token を発行して別 store key に格納)。
  // - GITHUB_PAT: GitHub fine-grained PAT (organization secrets: write scope
  //   必要)。read 専用 worker の token (read scope) とは別 token。
  //
  // secrets.required で CI / GCP Secret Manager 側にも対応 secret が存在する
  // ことを verify する。`*-write` suffix は read 用 token (`*-read`) と並列
  // しても衝突しないよう。
  "vars": {
    "CF_ACCESS_TEAM_DOMAIN": "mtamaramu.cloudflareaccess.com",
    "CF_ACCESS_AUD": "7cdf1cb650bc61c5827070e2a9df96166362f7c36934bcc5bf271c738af99b3f",
    "MCP_SERVER_NAME": "secrets-rotate-mcp",
    "MCP_SERVER_VERSION": "0.0.2",
    "MCP_PROTOCOL_VERSION": "2025-03-26",
    "GCP_PROJECT_ID": "cloudsql-sv",
    "GCP_PROXY_URL": "https://secrets-inventory-gcp-staging-566bls5vfq-an.a.run.app",
    "CF_ACCOUNT_ID": "24b45709d060d957340180e995f0d373",
    "CF_STORE_ID": "bd7bc91a3e5f4111add4acf6cb4b8733",
    "GITHUB_ORG": "ippoan",
    // /mcp* 認証先。auth-worker (`ippoan/auth-worker`) の `/mcp/introspect`
    // に binding_jwt を forward する。WWW-Authenticate header の
    // `resource_metadata` anchor にも使う。Refs #43。
    "AUTH_WORKER_ORIGIN": "https://auth.ippoan.org"
  },
  // 旧 `rotate-mcp-bearer` は #43 で削除 (auth-worker `binding_jwt` に切替、
  // shared secret 不要)。
  "secrets": {
    "required": [
      "secrets-inventory-gcp-proxy-api-key",
      "cf-secrets-inventory-secrets-store-write",
      "gh-secrets-inventory-org-secrets-write"
    ]
  },
  "env": {
    "staging": {
      "name": "secrets-rotate-mcp-staging",
      "account_id": "24b45709d060d957340180e995f0d373",
      // staging = 実 prod 運用。custom domain `security-rotate.ippoan.org` を
      // bind (= 既存 read worker `security-inventory.ippoan.org` と同 zone /
      // 同 CF Access app pattern)。workers_dev は明示 false で *.workers.dev
      // subdomain を無効化 (= URL を 1 本に絞り誤接続防止 + Access 適用漏れ
      // 防止)。
      //
      // CF Access application で同 hostname を保護する設定は user が CF
      // dashboard で追加する必要あり (= AUD は既存 secrets-inventory app と
      // 共通の `7cdf1cb6...` を流用、両 worker が 1 つの app 配下)。
      "workers_dev": false,
      "routes": [
        {
          "pattern": "security-rotate.ippoan.org",
          "custom_domain": true
        }
      ],
      "observability": { "enabled": true },
      "vars": {
        "CF_ACCESS_TEAM_DOMAIN": "mtamaramu.cloudflareaccess.com",
        "CF_ACCESS_AUD": "7cdf1cb650bc61c5827070e2a9df96166362f7c36934bcc5bf271c738af99b3f",
        "MCP_SERVER_NAME": "secrets-rotate-mcp",
        "MCP_SERVER_VERSION": "0.0.2",
        "MCP_PROTOCOL_VERSION": "2025-03-26",
        "GCP_PROJECT_ID": "cloudsql-sv",
        "GCP_PROXY_URL": "https://secrets-inventory-gcp-staging-566bls5vfq-an.a.run.app",
        "CF_ACCOUNT_ID": "24b45709d060d957340180e995f0d373",
        "CF_STORE_ID": "bd7bc91a3e5f4111add4acf6cb4b8733",
        "GITHUB_ORG": "ippoan",
        "AUTH_WORKER_ORIGIN": "https://auth-staging.ippoan.org"
      },
      "secrets_store_secrets": [
        {
          "binding": "GCP_PROXY_API_KEY",
          "store_id": "bd7bc91a3e5f4111add4acf6cb4b8733",
          "secret_name": "secrets-inventory-gcp-proxy-api-key"
        },
        {
          "binding": "CF_API_TOKEN",
          "store_id": "bd7bc91a3e5f4111add4acf6cb4b8733",
          "secret_name": "cf-secrets-inventory-secrets-store-write"
        },
        {
          "binding": "GITHUB_PAT",
          "store_id": "bd7bc91a3e5f4111add4acf6cb4b8733",
          "secret_name": "gh-secrets-inventory-org-secrets-write"
        }
      ]
    }
  }
}
